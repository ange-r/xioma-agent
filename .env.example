# ─── Agent account ───────────────────────────────────────────────────────────
# Receives x402 payments and signs earmarking transactions via multisig
AGENT_PRIVATE_KEY=S...
AGENT_PUBLIC_KEY=G...

# ─── Client account ──────────────────────────────────────────────────────────
# Pays for the x402 service and owns the sub-accounts
# Must have the agent configured as a secondary multisig signer (weight 1)
CLIENT_PRIVATE_KEY=S...
CLIENT_PUBLIC_KEY=G...

# ─── OpenZeppelin facilitator ────────────────────────────────────────────────
# Generate testnet key at: https://channels.openzeppelin.com/testnet/gen
# Generate mainnet key at: https://channels.openzeppelin.com/gen
OZ_API_KEY=your_openzeppelin_api_key

# ─── Stellar network ─────────────────────────────────────────────────────────
NETWORK=stellar:testnet
STELLAR_RPC_URL=https://soroban-testnet.stellar.org

# ─── USDC contract ───────────────────────────────────────────────────────────
# Derive with: node --input-type=module -e "
#   import pkg from '@stellar/stellar-sdk';
#   const { Asset } = pkg;
#   const asset = new Asset('USDC', 'GBBD47IF6LWK7P7MDEVSCWR7DPUWV3NY3DTQEVFL4NAT4AQH3ZLLFLA5');
#   console.log(asset.contractId('Test SDF Network ; September 2015'));"
USDC_CONTRACT_ID=C...

# ─── Client sub-accounts ─────────────────────────────────────────────────────
# One Stellar account per obligation category
# Each account must have a USDC trustline established before use
WALLET_SALARIES=G...
WALLET_SUPPLIERS=G...
WALLET_TAXES=G...
WALLET_SERVICES=G...
WALLET_OPERATING_CASH=G...